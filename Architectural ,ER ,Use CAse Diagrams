<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SecureOps — Report Diagrams</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'IBM Plex Sans', sans-serif;
  background: #f8f9fc;
  color: #1a1f2e;
  padding: 48px 32px;
}

/* PAGE CONTROLS */
.controls {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.tab-btn {
  padding: 10px 24px;
  border-radius: 8px;
  border: 2px solid #d1d5db;
  background: white;
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  color: #4b5563;
}

.tab-btn.active {
  background: #1a1f2e;
  border-color: #1a1f2e;
  color: white;
}

.tab-btn:hover:not(.active) {
  border-color: #1a1f2e;
  color: #1a1f2e;
}

/* DIAGRAM PAGE */
.diagram-page {
  display: none;
  max-width: 900px;
  margin: 0 auto;
}

.diagram-page.active { display: block; }

/* PAGE HEADER */
.page-header {
  text-align: center;
  margin-bottom: 36px;
  padding-bottom: 20px;
  border-bottom: 2px solid #e5e7eb;
}

.fig-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  color: #6b7280;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.page-header h2 {
  font-size: 20px;
  font-weight: 700;
  color: #1a1f2e;
  margin-bottom: 6px;
}

.page-header p {
  font-size: 13px;
  color: #6b7280;
}

/* PRINT BUTTON */
.print-btn {
  display: block;
  margin: 0 auto 28px;
  padding: 8px 20px;
  background: white;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 12px;
  font-family: 'IBM Plex Mono', monospace;
  cursor: pointer;
  color: #6b7280;
}

.print-btn:hover { background: #f3f4f6; }

/* =====================
   DIAGRAM 1: ARCHITECTURE
   ===================== */

.arch-diagram {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 36px;
}

.arch-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  margin-bottom: 0;
}

.arch-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px 20px;
  border-radius: 10px;
  text-align: center;
  min-width: 130px;
}

.arch-node .icon { font-size: 22px; margin-bottom: 6px; }
.arch-node .label {
  font-size: 12px;
  font-weight: 600;
  line-height: 1.3;
}
.arch-node .sublabel {
  font-size: 10px;
  font-family: 'IBM Plex Mono', monospace;
  margin-top: 3px;
  opacity: 0.75;
}

/* node colors */
.n-internet  { background:#eff6ff; border:2px solid #3b82f6; color:#1d4ed8; }
.n-nginx     { background:#f0fdf4; border:2px solid #22c55e; color:#15803d; }
.n-flask     { background:#faf5ff; border:2px solid #a855f7; color:#7e22ce; }
.n-admin     { background:#fff7ed; border:2px solid #f97316; color:#c2410c; }
.n-user      { background:#eff6ff; border:2px solid #3b82f6; color:#1d4ed8; }
.n-db        { background:#fef2f2; border:2px solid #ef4444; color:#b91c1c; }
.n-docker    { background:#e0f2fe; border:2px solid #0284c7; color:#075985; }
.n-ec2       { background:#fff7ed; border:2px solid #f97316; color:#c2410c; }
.n-cicd      { background:#f0fdf4; border:2px solid #22c55e; color:#15803d; }
.n-cw        { background:#fef9c3; border:2px solid #eab308; color:#854d0e; }
.n-s3        { background:#fff7ed; border:2px solid #fb923c; color:#c2410c; }
.n-security  { background:#fdf4ff; border:2px solid #c026d3; color:#86198f; }

/* ARROW */
.arch-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #9ca3af;
  font-size: 18px;
  margin: 2px 0;
}

.arch-arrow span {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  color: #9ca3af;
  letter-spacing: 1px;
  margin-top: 2px;
}

.arch-split {
  display: flex;
  justify-content: center;
  gap: 40px;
  position: relative;
  margin: 2px 0;
}

.arch-split::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 200px);
  height: 2px;
  background: #e5e7eb;
}

.arch-merge-line {
  width: 2px;
  height: 24px;
  background: #e5e7eb;
  margin: 0 auto;
}

.arch-bottom-row {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 4px;
}

/* LEGEND */
.arch-legend {
  margin-top: 24px;
  padding-top: 16px;
  border-top: 1px solid #f3f4f6;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: #6b7280;
}

.legend-dot {
  width: 10px; height: 10px;
  border-radius: 3px;
}

/* =====================
   DIAGRAM 2: USE CASE
   ===================== */

.uc-diagram {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 36px;
}

.uc-layout {
  display: grid;
  grid-template-columns: 100px 1fr 100px;
  gap: 16px;
  align-items: start;
}

.actor {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding-top: 24px;
}

.actor-icon {
  width: 44px; height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  border: 2px solid;
}

.actor-user  { background:#eff6ff; border-color:#3b82f6; }
.actor-admin { background:#fff7ed; border-color:#f97316; }

.actor-name {
  font-size: 12px;
  font-weight: 600;
  text-align: center;
  color: #374151;
}

.uc-system {
  border: 2px solid #1a1f2e;
  border-radius: 12px;
  overflow: hidden;
}

.uc-system-title {
  background: #1a1f2e;
  color: white;
  text-align: center;
  padding: 10px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
}

.uc-modules {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.uc-module {
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid #e5e7eb;
}

.uc-module-header {
  padding: 7px 12px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.uc-cases {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 8px 10px;
  background: white;
}

.uc-case {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
  border: 1px solid;
}

/* module colors */
.m-auth   .uc-module-header { background:#eff6ff; color:#1d4ed8; }
.m-auth   .uc-case          { background:#eff6ff; border-color:#bfdbfe; color:#1d4ed8; }

.m-task   .uc-module-header { background:#f0fdf4; color:#15803d; }
.m-task   .uc-case          { background:#f0fdf4; border-color:#bbf7d0; color:#15803d; }

.m-proj   .uc-module-header { background:#faf5ff; color:#7e22ce; }
.m-proj   .uc-case          { background:#faf5ff; border-color:#e9d5ff; color:#7e22ce; }

.m-anal   .uc-module-header { background:#fef9c3; color:#854d0e; }
.m-anal   .uc-case          { background:#fef9c3; border-color:#fde68a; color:#854d0e; }

.m-admin  .uc-module-header { background:#fff7ed; color:#c2410c; }
.m-admin  .uc-case          { background:#fff7ed; border-color:#fed7aa; color:#c2410c; }

.m-sec    .uc-module-header { background:#fdf4ff; color:#86198f; }
.m-sec    .uc-case          { background:#fdf4ff; border-color:#f0abfc; color:#86198f; }

/* =====================
   DIAGRAM 3: ER DIAGRAM
   ===================== */

.er-diagram {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 36px;
}

.er-layout {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.er-center { display: flex; justify-content: center; }

.er-sides {
  display: flex;
  gap: 32px;
  justify-content: center;
  align-items: flex-start;
}

.er-table {
  border: 2px solid #1a1f2e;
  border-radius: 10px;
  overflow: hidden;
  min-width: 220px;
  flex: 1;
  max-width: 280px;
}

.er-table-header {
  background: #1a1f2e;
  color: white;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.er-table-header .icon { font-size: 16px; }

.er-table-header .name {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.er-table-header .tablename {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  opacity: 0.6;
  margin-left: auto;
}

.er-field {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  border-bottom: 1px solid #f3f4f6;
  font-size: 12px;
}

.er-field:last-child { border-bottom: none; }

.er-field .field-name {
  font-family: 'IBM Plex Mono', monospace;
  font-weight: 500;
  color: #374151;
  flex: 1;
}

.er-field .field-type {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: #9ca3af;
}

.er-field .pk-badge {
  font-size: 9px;
  font-weight: 700;
  padding: 1px 5px;
  border-radius: 3px;
  background: #fef9c3;
  color: #854d0e;
  border: 1px solid #fde68a;
}

.er-field .fk-badge {
  font-size: 9px;
  font-weight: 700;
  padding: 1px 5px;
  border-radius: 3px;
  background: #eff6ff;
  color: #1d4ed8;
  border: 1px solid #bfdbfe;
}

.er-field .uniq-badge {
  font-size: 9px;
  font-weight: 700;
  padding: 1px 5px;
  border-radius: 3px;
  background: #f0fdf4;
  color: #15803d;
  border: 1px solid #bbf7d0;
}

/* RELATIONSHIP LINES */
.er-rel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-size: 11px;
  color: #6b7280;
  font-family: 'IBM Plex Mono', monospace;
}

.er-rel-line {
  height: 2px;
  width: 60px;
  background: #d1d5db;
  position: relative;
}

.er-rel-line::after {
  content: '▶';
  position: absolute;
  right: -6px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 10px;
  color: #9ca3af;
}

.er-rel-vertical {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: #6b7280;
  font-family: 'IBM Plex Mono', monospace;
}

.er-rel-vline {
  width: 2px;
  height: 32px;
  background: #d1d5db;
  position: relative;
}

.er-rel-vline::after {
  content: '▼';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 10px;
  color: #9ca3af;
}

.er-rel-box {
  background: #f9fafb;
  border: 1px dashed #d1d5db;
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 11px;
  color: #6b7280;
  font-family: 'IBM Plex Mono', monospace;
  white-space: nowrap;
}

/* ER table header colors */
.er-user   .er-table-header { background: #1d4ed8; }
.er-task   .er-table-header { background: #15803d; }
.er-proj   .er-table-header { background: #7e22ce; }

@media print {
  .controls, .print-btn { display: none !important; }
  .diagram-page { display: block !important; page-break-after: always; }
}

@media (max-width: 700px) {
  .uc-layout { grid-template-columns: 1fr; }
  .er-sides  { flex-direction: column; align-items: center; }
  .arch-split { flex-direction: column; gap: 8px; }
  .arch-split::before { display: none; }
}
</style>
</head>
<body>

<!-- TABS -->
<div class="controls">
  <button class="tab-btn active" onclick="showTab('arch')">Figure 4.1 — Architecture</button>
  <button class="tab-btn"        onclick="showTab('uc')">Figure 4.2 — Use Case</button>
  <button class="tab-btn"        onclick="showTab('er')">Figure 4.3 — ER Diagram</button>
</div>

<!-- ================================
     DIAGRAM 1: ARCHITECTURE
     ================================ -->
<div class="diagram-page active" id="tab-arch">

  <div class="page-header">
    <p class="fig-label">Figure 4.1</p>
    <h2>System Architecture Diagram</h2>
    <p>SecureOps Enterprise DevSecOps Platform — End-to-End Architecture</p>
  </div>

  <button class="print-btn" onclick="window.print()">🖨️ Print / Save as PDF</button>

  <div class="arch-diagram">

    <!-- Internet -->
    <div class="arch-row">
      <div class="arch-node n-internet">
        <div class="icon">🌐</div>
        <div class="label">Internet / Browser</div>
        <div class="sublabel">HTTPS : 443</div>
      </div>
    </div>

    <div class="arch-arrow">↓<span>HTTPS / TLS</span></div>

    <!-- CI/CD + Nginx side by side -->
    <div class="arch-row" style="gap:24px;">
      <div class="arch-node n-cicd" style="min-width:140px;">
        <div class="icon">⚡</div>
        <div class="label">GitHub Actions CI/CD</div>
        <div class="sublabel">Bandit · Trivy · Docker build</div>
      </div>
      <div class="arch-node n-nginx" style="min-width:160px;">
        <div class="icon">🔀</div>
        <div class="label">Nginx Reverse Proxy</div>
        <div class="sublabel">Port 80/443 → 5000</div>
      </div>
      <div class="arch-node n-security" style="min-width:140px;">
        <div class="icon">🛡️</div>
        <div class="label">Security Layer</div>
        <div class="sublabel">Headers · CSRF · Rate Limit</div>
      </div>
    </div>

    <div class="arch-arrow">↓<span>Gunicorn WSGI</span></div>

    <!-- Flask App -->
    <div class="arch-row">
      <div class="arch-node n-flask" style="min-width:320px; padding:18px 28px;">
        <div class="icon">🐍</div>
        <div class="label">Flask Application — SecureOps</div>
        <div class="sublabel">Routes · RBAC · Auth · Business Logic</div>
      </div>
    </div>

    <!-- Split to Admin + User -->
    <div class="arch-split">
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
        <div style="width:2px;height:20px;background:#e5e7eb;"></div>
        <div class="arch-node n-admin">
          <div class="icon">👑</div>
          <div class="label">Admin Panel</div>
          <div class="sublabel">User Mgmt · Analytics</div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
        <div style="width:2px;height:20px;background:#e5e7eb;"></div>
        <div class="arch-node n-user">
          <div class="icon">👤</div>
          <div class="label">User Dashboard</div>
          <div class="sublabel">Tasks · Projects · Profile</div>
        </div>
      </div>
    </div>

    <!-- Merge back -->
    <div class="arch-arrow">↓<span>SQLAlchemy ORM</span></div>

    <!-- PostgreSQL -->
    <div class="arch-row">
      <div class="arch-node n-db" style="min-width:200px;">
        <div class="icon">🗄️</div>
        <div class="label">PostgreSQL Database</div>
        <div class="sublabel">users · tasks · projects</div>
      </div>
    </div>

    <div class="arch-arrow">↓<span>Containerized</span></div>

    <!-- Docker + S3 -->
    <div class="arch-row" style="gap:24px;">
      <div class="arch-node n-docker">
        <div class="icon">🐳</div>
        <div class="label">Docker + Compose</div>
        <div class="sublabel">app + db containers</div>
      </div>
      <div class="arch-node n-s3">
        <div class="icon">🪣</div>
        <div class="label">AWS S3</div>
        <div class="sublabel">Static · Backups</div>
      </div>
    </div>

    <div class="arch-arrow">↓<span>Deployed on</span></div>

    <!-- EC2 -->
    <div class="arch-row">
      <div class="arch-node n-ec2" style="min-width:200px;">
        <div class="icon">☁️</div>
        <div class="label">AWS EC2 Instance</div>
        <div class="sublabel">Ubuntu · Private Subnet · VPC</div>
      </div>
    </div>

    <div class="arch-arrow">↓<span>Monitored by</span></div>

    <!-- CloudWatch -->
    <div class="arch-row">
      <div class="arch-node n-cw" style="min-width:200px;">
        <div class="icon">📊</div>
        <div class="label">AWS CloudWatch</div>
        <div class="sublabel">Logs · Metrics · Alerts</div>
      </div>
    </div>

    <!-- LEGEND -->
    <div class="arch-legend">
      <div class="legend-item"><div class="legend-dot" style="background:#3b82f6;"></div>Client / User</div>
      <div class="legend-item"><div class="legend-dot" style="background:#22c55e;"></div>Networking</div>
      <div class="legend-item"><div class="legend-dot" style="background:#a855f7;"></div>Application</div>
      <div class="legend-item"><div class="legend-dot" style="background:#ef4444;"></div>Database</div>
      <div class="legend-item"><div class="legend-dot" style="background:#0284c7;"></div>Container</div>
      <div class="legend-item"><div class="legend-dot" style="background:#f97316;"></div>AWS Cloud</div>
      <div class="legend-item"><div class="legend-dot" style="background:#c026d3;"></div>Security</div>
    </div>

  </div>
</div>

<!-- ================================
     DIAGRAM 2: USE CASE
     ================================ -->
<div class="diagram-page" id="tab-uc">

  <div class="page-header">
    <p class="fig-label">Figure 4.2</p>
    <h2>Use Case Diagram</h2>
    <p>SecureOps Platform — Actor Interactions and System Use Cases</p>
  </div>

  <button class="print-btn" onclick="window.print()">🖨️ Print / Save as PDF</button>

  <div class="uc-diagram">
    <div class="uc-layout">

      <!-- LEFT ACTOR: Regular User -->
      <div class="actor">
        <div class="actor-icon actor-user">👤</div>
        <div class="actor-name">Regular<br>User</div>
      </div>

      <!-- SYSTEM -->
      <div class="uc-system">
        <div class="uc-system-title">«SYSTEM» SecureOps Platform</div>
        <div class="uc-modules">

          <!-- AUTH -->
          <div class="uc-module m-auth">
            <div class="uc-module-header">🔐 Authentication Module</div>
            <div class="uc-cases">
              <span class="uc-case">Register Account</span>
              <span class="uc-case">Login</span>
              <span class="uc-case">Logout</span>
              <span class="uc-case">Forgot Password</span>
              <span class="uc-case">Session Management</span>
            </div>
          </div>

          <!-- TASK -->
          <div class="uc-module m-task">
            <div class="uc-module-header">✅ Task Management</div>
            <div class="uc-cases">
              <span class="uc-case">Create Task</span>
              <span class="uc-case">View Tasks</span>
              <span class="uc-case">Edit Task</span>
              <span class="uc-case">Delete Task</span>
              <span class="uc-case">Set Priority</span>
              <span class="uc-case">Update Status</span>
            </div>
          </div>

          <!-- PROJECT -->
          <div class="uc-module m-proj">
            <div class="uc-module-header">📁 Project Management</div>
            <div class="uc-cases">
              <span class="uc-case">Create Project</span>
              <span class="uc-case">View Projects</span>
              <span class="uc-case">Edit Project</span>
              <span class="uc-case">Delete Project</span>
              <span class="uc-case">Track Progress</span>
            </div>
          </div>

          <!-- ANALYTICS -->
          <div class="uc-module m-anal">
            <div class="uc-module-header">📊 Analytics</div>
            <div class="uc-cases">
              <span class="uc-case">View Dashboard</span>
              <span class="uc-case">Task Metrics</span>
              <span class="uc-case">Completion Rate</span>
              <span class="uc-case">Live Stats</span>
            </div>
          </div>

          <!-- ADMIN ONLY -->
          <div class="uc-module m-admin">
            <div class="uc-module-header">👑 Admin Management (Admin Only)</div>
            <div class="uc-cases">
              <span class="uc-case">Create Employee</span>
              <span class="uc-case">Edit Employee</span>
              <span class="uc-case">Delete Employee</span>
              <span class="uc-case">Enable / Disable User</span>
              <span class="uc-case">Assign Role</span>
              <span class="uc-case">View All Tasks</span>
            </div>
          </div>

          <!-- SECURITY -->
          <div class="uc-module m-sec">
            <div class="uc-module-header">🛡️ Security (System)</div>
            <div class="uc-cases">
              <span class="uc-case">CSRF Protection</span>
              <span class="uc-case">Rate Limiting</span>
              <span class="uc-case">RBAC Enforcement</span>
              <span class="uc-case">Security Headers</span>
              <span class="uc-case">Bcrypt Hashing</span>
            </div>
          </div>

        </div>
      </div>

